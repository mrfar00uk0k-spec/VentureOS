# ============================================================
# VentureOS — Environment Variables
# ============================================================

# --- Database ---
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/ventureos"

# --- Cache / Queue ---
REDIS_URL="redis://localhost:6379"

# --- Auth ---
JWT_SECRET="replace-with-a-long-random-string"
WEB_APP_URL="http://localhost:3000"
OAUTH_REDIRECT_BASE_URL="http://localhost:4000"
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GITHUB_CLIENT_ID=""
GITHUB_CLIENT_SECRET=""

# ============================================================
# AI PROVIDERS — multi-key, auto-rotation, free tiers first
# ============================================================
# Comma-separated list of API keys (up to 50 per provider).
# Keys are tried round-robin; rate-limited keys cool down for 60s;
# invalid keys are excluded permanently for the session.
#
# Free tiers:
#   Groq   → console.groq.com  (no card needed, rate-limited per account)
#   Gemini → aistudio.google.com/apikey  (free Flash models, no card needed)
#   OpenAI → platform.openai.com  (no meaningful free tier — optional)
#
# IMPORTANT: Groq and Gemini rate-limit at the account level, not per key.
# Keys from the same account share one quota. For extra throughput you
# need keys from genuinely separate accounts on each provider.
# ---------------------------------------------------------
GROQ_API_KEYS="gsk_key1,gsk_key2,gsk_key3"
GEMINI_API_KEYS="AIzaSy_key1,AIzaSy_key2"
OPENAI_API_KEYS=""   # optional — paid only, used as last-resort fallback

# Which provider:model pairs to try for each tier, in order.
# Groq runs first (fastest), then Gemini, then OpenAI if configured.
# Each step can be any "provider:model" pair where the provider name
# matches GROQ_API_KEYS / GEMINI_API_KEYS / OPENAI_API_KEYS above.
AI_FAST_CHAIN="groq:llama-3.1-8b-instant,gemini:gemini-2.5-flash-lite"
AI_REASONING_CHAIN="groq:llama-3.3-70b-versatile,gemini:gemini-2.5-flash"

# ============================================================
# SEARCH PROVIDERS — multi-key, auto-rotation
# ============================================================
# Comma-separated list of API keys (up to 50 per provider).
# Tavily is the default (free 1,000 credits/month per account).
# Brave is the automatic fallback (free tier also available).
# ---------------------------------------------------------
TAVILY_API_KEYS="tvly-key1,tvly-key2,tvly-key3"
BRAVE_SEARCH_API_KEYS="BSA_key1,BSA_key2"   # fallback

# Which search providers to try, in order.
SEARCH_CHAIN="tavily,brave"

# ============================================================
# BILLING
# ============================================================
STRIPE_SECRET_KEY=""
STRIPE_WEBHOOK_SECRET=""
STRIPE_PRICE_STARTER=""
STRIPE_PRICE_PRO=""

# --- Server ---
PORT=4000
NODE_ENV="development"
